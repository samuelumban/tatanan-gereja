  `;
  
  document.body.appendChild(reflectionCard);
  
  html2canvas(reflectionCard, {
    scale: 2,
    backgroundColor: '#FFFFFF'
  }).then(canvas => {
    const link = document.createElement('a');
    link.download = 'Refleksi_Tatanan_Gereja_' + Date.now() + '.jpg';
