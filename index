<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Tatanan Gereja Perjanjian Baru</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
:root {
  --bg-primary: #E8F4FD;
  --bg-card: #FFFFFF;
  --blue-deep: #1B3A5C;
  --blue-mid: #2E6DA4;
  --blue-light: #B8D8F0;
  --orange: #F28C28;
  --orange-hover: #E07B1A;
  --orange-light: #FFF3E6;
  --green: #4CAF50;
  --green-light: #E8F5E9;
  --green-bright: #66BB6A;
  --red-soft: #FFCDD2;
  --red: #E57373;
  --purple: #7E57C2;
  --purple-light: #F3E5F5;
  --yellow-note: #FFF9C4;
  --yellow-border: #FFD54F;
  --text-dark: #1a1a2e;
  --text-body: #333344;
  --text-muted: #666680;
  --shadow: 0 4px 20px rgba(27,58,92,0.08);
  --shadow-lg: 0 8px 32px rgba(27,58,92,0.12);
  --radius: 16px;
  --radius-sm: 10px;
}

* { margin:0; padding:0; box-sizing:border-box; }

html { scroll-behavior: smooth; }

body {
  font-family: 'Nunito', sans-serif;
  background: var(--bg-primary);
  color: var(--text-body);
  line-height: 1.75;
  font-size: 16px;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ===== SPLASH SCREEN ===== */
.splash {
  position: fixed; inset:0; z-index:9999;
  background: linear-gradient(135deg, #1B3A5C 0%, #2E6DA4 50%, #7E57C2 100%);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  transition: opacity 0.8s, transform 0.8s;
}
.splash.hide { opacity:0; transform: scale(1.1); pointer-events:none; }
.splash h1 {
  font-family: 'Playfair Display', serif;
  color: white; font-size: clamp(1.6rem,5vw,2.4rem);
  text-align: center; margin-bottom: 8px;
  animation: fadeUp 1s ease-out;
}
.splash p {
  color: rgba(255,255,255,0.8); font-size: clamp(0.9rem,3vw,1.1rem);
  text-align: center; margin-bottom: 6px;
  animation: fadeUp 1s 0.2s ease-out both;
}
.splash .subtitle {
  color: rgba(255,255,255,0.6); font-size: clamp(0.8rem,2.5vw,0.95rem);
  margin-bottom: 32px; animation: fadeUp 1s 0.35s ease-out both;
}
.btn-start {
  background: var(--orange); color: white; border: none;
  padding: 16px 48px; border-radius: 50px;
  font-family: 'Nunito', sans-serif;
  font-size: 1.1rem; font-weight: 700;
  cursor: pointer; animation: fadeUp 1s 0.8s ease-out both;
  transition: all 0.3s; box-shadow: 0 4px 20px rgba(242,140,40,0.4);
}
.btn-start:hover { background: var(--orange-hover); transform: translateY(-2px); box-shadow: 0 6px 28px rgba(242,140,40,0.5); }

/* ===== HEADER / PROGRESS ===== */
.top-bar {
  position: sticky; top:0; z-index:100;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10px);
  padding: 12px 20px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
.top-bar-inner {
  max-width: 720px; margin: 0 auto;
  display: flex; align-items: center; gap: 12px;
}
.progress-track {
  flex:1; height: 10px; background: #E0E0E0;
  border-radius: 5px; overflow: hidden;
}
.progress-fill {
  height:100%; width:0%; border-radius: 5px;
  background: linear-gradient(90deg, var(--green), var(--green-bright));
  transition: width 0.6s cubic-bezier(0.4,0,0.2,1);
}
.progress-label {
  font-size: 0.8rem; font-weight: 700;
  color: var(--green); white-space: nowrap;
}

/* ===== MAIN CONTAINER ===== */
.container {
  max-width: 720px; margin: 0 auto;
  padding: 20px 16px 100px;
}

/* ===== CHUNK CARDS ===== */
.chunk {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: clamp(20px,4vw,32px);
  margin-bottom: 20px;
  box-shadow: var(--shadow);
  display: none;
  animation: slideUp 0.5s ease-out;
  position: relative;
  overflow: hidden;
}
.chunk.active { display: block; }
.chunk::before {
  content: ''; position: absolute; top:0; left:0; right:0;
  height: 4px;
}
.chunk.chunk-intro::before { background: var(--blue-mid); }
.chunk.chunk-timeline::before { background: var(--purple); }
.chunk.chunk-concept::before { background: var(--orange); }
.chunk.chunk-apply::before { background: var(--green); }
.chunk.chunk-summary::before { background: var(--blue-deep); }
.chunk.chunk-reflect::before { background: linear-gradient(90deg, var(--purple), var(--orange)); }

.chunk-number {
  display: inline-block;
  background: var(--blue-light);
  color: var(--blue-deep);
  font-size: 0.75rem; font-weight: 800;
  padding: 4px 12px; border-radius: 20px;
  margin-bottom: 12px; letter-spacing: 0.5px;
}

h2 {
  font-family: 'Playfair Display', serif;
  color: var(--blue-deep);
  font-size: clamp(1.3rem, 4vw, 1.6rem);
  margin-bottom: 16px; line-height: 1.3;
}

h3 {
  color: var(--blue-deep);
  font-size: clamp(1.05rem, 3vw, 1.2rem);
  margin: 20px 0 10px; font-weight: 700;
}

p { margin-bottom: 14px; }

/* ===== IMAGE CONTAINERS ===== */
.img-container {
  text-align: center; margin: 16px 0;
  border-radius: var(--radius-sm); overflow: hidden;
  background: #f5f5f5;
}
.img-container img {
  max-width: 100%; height: auto;
  border-radius: var(--radius-sm);
}
.img-caption {
  font-size: 0.8rem; color: var(--text-muted);
  padding: 8px; font-style: italic;
}

/* ===== MASCOT TIP BOX ===== */
.tip-box {
  background: var(--yellow-note);
  border-radius: var(--radius-sm);
  padding: 18px 20px 18px 90px;
  margin: 28px 0 20px;
  position: relative;
  min-height: 100px;
  display: flex;
  align-items: center;
}
.tip-box .mascot-img {
  position: absolute;
  left: -8px; bottom: -4px;
  width: 90px; height: auto;
  filter: drop-shadow(2px 2px 6px rgba(0,0,0,0.12));
  z-index: 2;
}
.tip-box .tip-label {
  color: var(--orange);
  font-weight: 800;
  font-size: 1rem;
  margin-bottom: 4px;
}
.tip-box .tip-text {
  font-size: 0.9rem;
  color: var(--text-body);
  margin: 0;
}

/* ===== TAHUKAH KAMU (NOTEBOOK STYLE) ===== */
.tahukah-box {
  background: #FFFEF5;
  border: 1px solid #E8E0C8;
  border-radius: var(--radius-sm);
  padding: 20px 20px 20px 24px;
  margin: 20px 0;
  position: relative;
  box-shadow: 2px 2px 8px rgba(0,0,0,0.04);
  background-image:
    repeating-linear-gradient(transparent, transparent 27px, #E8E0C8 27px, #E8E0C8 28px);
  background-position: 0 20px;
}
.tahukah-box::before {
  content: ''; position: absolute; left: 18px; top: 0; bottom: 0;
  width: 2px; background: #FFCCCC; opacity: 0.5;
}
.tahukah-header {
  display: flex; align-items: center; gap: 8px;
  margin-bottom: 10px; position: relative; z-index: 1;
}
.tahukah-header .lamp {
  font-size: 1.3rem;
}
.tahukah-header span {
  font-weight: 800; color: var(--orange);
  font-size: 1rem;
  background: #FFFEF5;
  padding-right: 8px;
}
.tahukah-text {
  font-size: 0.92rem;
  line-height: 1.97;
  position: relative; z-index: 1;
  margin: 0;
  background: transparent;
}

/* ===== PETA PIKIRAN ===== */
.mindmap { text-align: center; margin: 20px 0; }
.mindmap-placeholder {
  background: linear-gradient(135deg, #F0F4FF, #E8F0FE);
  border: 2px dashed var(--blue-light);
  border-radius: var(--radius-sm);
  padding: 40px 20px;
  text-align: center;
  color: var(--blue-mid);
  font-weight: 600;
}

/* ===== TIMELINE ===== */
.timeline {
  position: relative;
  padding-left: 28px;
  margin: 20px 0;
}
.timeline::before {
  content: ''; position: absolute; left: 8px;
  top: 0; bottom: 0; width: 3px;
  background: linear-gradient(180deg, var(--purple), var(--purple-light));
  border-radius: 2px;
}
.tl-item {
  position: relative;
  margin-bottom: 20px;
  padding: 14px 16px;
  background: var(--purple-light);
  border-radius: var(--radius-sm);
  border-left: 3px solid var(--purple);
}
.tl-item::before {
  content: ''; position: absolute;
  left: -24px; top: 18px;
  width: 12px; height: 12px;
  background: var(--purple);
  border-radius: 50%;
  border: 3px solid white;
  box-shadow: 0 0 0 2px var(--purple);
}
.tl-year {
  font-weight: 800; color: var(--purple);
  font-size: 0.85rem;
}
.tl-desc {
  font-size: 0.9rem; margin: 0;
}

/* ===== QUIZ STYLES ===== */
.quiz-block {
  margin: 24px 0;
  padding: 20px;
  background: linear-gradient(135deg, #F8FBFF, #F0F4FF);
  border-radius: var(--radius);
  border: 2px solid var(--blue-light);
}
.quiz-question {
  font-weight: 700; color: var(--blue-deep);
  margin-bottom: 14px; font-size: 1rem;
}
.quiz-options {
  display: flex; flex-direction: column; gap: 10px;
}
.quiz-option {
  background: white;
  border: 2px solid #E0E0E0;
  border-radius: var(--radius-sm);
  padding: 14px 16px;
  cursor: pointer;
  transition: all 0.3s;
  font-size: 0.95rem;
  display: flex; align-items: center; gap: 10px;
}
.quiz-option:hover { border-color: var(--blue-mid); background: #F8FBFF; }
.quiz-option.correct { 
  background: var(--green-light); 
  border-color: var(--green);
  animation: correctPulse 0.5s;
}
.quiz-option.wrong { 
  background: var(--red-soft); 
  border-color: var(--red);
  animation: shake 0.5s;
}
.quiz-option.disabled { pointer-events: none; opacity: 0.6; }

.quiz-input {
  margin-top: 10px;
}
.quiz-input input {
  width: 100%;
  padding: 12px 16px;
  border: 2px solid #E0E0E0;
  border-radius: var(--radius-sm);
  font-family: 'Nunito', sans-serif;
  font-size: 1rem;
  transition: border-color 0.3s;
}
.quiz-input input:focus {
  outline: none;
  border-color: var(--blue-mid);
}

.quiz-feedback {
  margin-top: 12px;
  padding: 12px;
  border-radius: var(--radius-sm);
  font-size: 0.9rem;
  display: none;
}
.quiz-feedback.show { display: block; }
.quiz-feedback.correct {
  background: var(--green-light);
  color: var(--green);
  border: 1px solid var(--green);
}
.quiz-feedback.wrong {
  background: var(--red-soft);
  color: var(--red);
  border: 1px solid var(--red);
}

.quiz-submit {
  margin-top: 12px;
  background: var(--orange);
  color: white;
  border: none;
  padding: 12px 24px;
  border-radius: var(--radius-sm);
  font-family: 'Nunito', sans-serif;
  font-size: 0.95rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s;
}
.quiz-submit:hover {
  background: var(--orange-hover);
  transform: translateY(-2px);
}
.quiz-submit:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* ===== DRAG & DROP ===== */
.drag-container {
  margin: 20px 0;
}
.drag-items {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 20px;
  min-height: 50px;
  padding: 12px;
  background: #F8FBFF;
  border-radius: var(--radius-sm);
  border: 2px dashed var(--blue-light);
}
.drag-item {
  background: white;
  border: 2px solid var(--blue-light);
  border-radius: var(--radius-sm);
  padding: 10px 16px;
  cursor: grab;
  font-size: 0.9rem;
  transition: all 0.3s;
  user-select: none;
}
.drag-item:active { cursor: grabbing; }
.drag-item.dragging { opacity: 0.5; }

.drop-zones {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.drop-zone {
  background: white;
  border: 2px dashed #E0E0E0;
  border-radius: var(--radius-sm);
  padding: 16px;
  min-height: 60px;
  transition: all 0.3s;
}
.drop-zone.drag-over {
  background: #F0F4FF;
  border-color: var(--blue-mid);
}
.drop-zone-label {
  font-weight: 700;
  color: var(--blue-deep);
  margin-bottom: 8px;
  font-size: 0.9rem;
}

/* ===== BUTTONS ===== */
.navigation-buttons {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12px;
  margin: 24px auto 0;
}

.btn-back {
  background: var(--blue-light);
  color: var(--blue-deep);
  border: 2px solid var(--blue-mid);
  padding: 12px 28px;
  border-radius: 50px;
  font-family: 'Nunito', sans-serif;
  font-size: 0.95rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s;
  display: none;
}
.btn-back.show { display: block; }
.btn-back:hover {
  background: var(--blue-mid);
  color: white;
  transform: translateY(-2px);
}

.btn-next {
  background: var(--orange);
  color: white;
  border: none;
  padding: 14px 32px;
  border-radius: 50px;
  font-family: 'Nunito', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s;
  box-shadow: 0 4px 12px rgba(242,140,40,0.3);
  display: none;
}
.btn-next.show { display: block; }
.btn-next:hover {
  background: var(--orange-hover);
  transform: translateY(-2px);
  box-shadow: 0 6px 16px rgba(242,140,40,0.4);
}

/* ===== SUMMARY BOX ===== */
.summary-box {
  background: linear-gradient(135deg, #F0F4FF, #E8F0FE);
  border-left: 4px solid var(--blue-deep);
  border-radius: var(--radius-sm);
  padding: 20px;
  margin: 20px 0;
}
.summary-box h3 {
  margin-top: 0;
}
.summary-box ul {
  margin: 10px 0 10px 20px;
}
.summary-box li {
  margin-bottom: 8px;
  line-height: 1.6;
}

.btn-download-summary {
  background: var(--blue-mid);
  color: white;
  border: none;
  padding: 12px 24px;
  border-radius: var(--radius-sm);
  font-family: 'Nunito', sans-serif;
  font-size: 0.95rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s;
  margin-top: 16px;
}
.btn-download-summary:hover {
  background: var(--blue-deep);
  transform: translateY(-2px);
}

/* ===== REFLECTION ===== */
.reflection-form {
  margin: 20px 0;
}
.reflection-item {
  margin-bottom: 20px;
}
.reflection-item label {
  display: block;
  font-weight: 700;
  color: var(--blue-deep);
  margin-bottom: 8px;
  font-size: 0.95rem;
}
.reflection-item textarea {
  width: 100%;
  padding: 12px;
  border: 2px solid #E0E0E0;
  border-radius: var(--radius-sm);
  font-family: 'Nunito', sans-serif;
  font-size: 0.95rem;
  resize: vertical;
  min-height: 80px;
  transition: border-color 0.3s;
}
.reflection-item textarea:focus {
  outline: none;
  border-color: var(--blue-mid);
}

.btn-save-reflection {
  background: var(--green);
  color: white;
  border: none;
  padding: 14px 32px;
  border-radius: 50px;
  font-family: 'Nunito', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s;
  box-shadow: 0 4px 12px rgba(76,175,80,0.3);
}
.btn-save-reflection:hover {
  background: var(--green-bright);
  transform: translateY(-2px);
  box-shadow: 0 6px 16px rgba(76,175,80,0.4);
}

/* ===== ANIMATIONS ===== */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes correctPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.02); }
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-5px); }
  75% { transform: translateX(5px); }
}

/* ===== RESPONSIVE ===== */
@media (max-width: 600px) {
  .tip-box {
    padding: 18px 16px 18px 75px;
  }
  .tip-box .mascot-img {
    width: 70px;
  }
}

/* Responsive Design */
@media screen and (min-width: 1200px) {
    .container {
        max-width: 1400px;
        padding: 40px;
    }
    .section {
        padding: 40px;
    }
}

@media screen and (min-width: 768px) and (max-width: 1199px) {
    .container {
        max-width: 960px;
        padding: 30px;
    }
}

@media screen and (max-width: 767px) {
    .container {
        max-width: 100%;
        padding: 15px;
    }
    .section {
        padding: 20px 15px;
    }
    h1 {
        font-size: 1.8rem;
    }
    h2 {
        font-size: 1.5rem;
    }
}

</style>
</head>
