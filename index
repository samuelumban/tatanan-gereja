// ===== DRAG AND DROP =====
let draggedItem = null;
const correctPairs = {
  '1': '1',
  '2': '2',
  '3': '3'
};
let matchedPairs = 0;

function initDragDrop() {
  const dragItems = document.querySelectorAll('.drag-item');
  const dropZones = document.querySelectorAll('.drop-zone');
  
  dragItems.forEach(item => {
    item.addEventListener('dragstart', handleDragStart);
    item.addEventListener('dragend', handleDragEnd);
  });
  
  dropZones.forEach(zone => {
    zone.addEventListener('dragover', handleDragOver);
    zone.addEventListener('drop', handleDrop);
    zone.addEventListener('dragleave', handleDragLeave);
  });
}

function handleDragStart(e) {
  draggedItem = this;
  this.classList.add('dragging');
  e.dataTransfer.effectAllowed = 'move';
}

function handleDragEnd(e) {
  this.classList.remove('dragging');
}

function handleDragOver(e) {
  if (e.preventDefault) {
    e.preventDefault();
  }
  this.classList.add('drag-over');
  e.dataTransfer.dropEffect = 'move';
  return false;
}

function handleDragLeave(e) {
  this.classList.remove('drag-over');
}

function handleDrop(e) {
  if (e.stopPropagation) {
    e.stopPropagation();
  }
  
  this.classList.remove('drag-over');
  
  const zoneAnswer = this.getAttribute('data-answer');
  const itemId = draggedItem.getAttribute('data-id');
  
  if (correctPairs[itemId] === zoneAnswer) {
    this.appendChild(draggedItem);
    draggedItem.style.border = '2px solid var(--green)';
    draggedItem.style.background = 'var(--green-light)';
    draggedItem.draggable = false;
    matchedPairs++;
    
    if (matchedPairs === 3) {
      document.getElementById('btn-chunk5').classList.add('show');
    }
  } else {
    draggedItem.style.animation = 'shake 0.5s';
    setTimeout(() => {
      draggedItem.style.animation = '';
    }, 500);
  }
  
  return false;
}

