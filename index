    document.getElementById('splash').style.display = 'none';
    document.getElementById('topBar').style.display = 'block';
    document.getElementById('mainContent').style.display = 'block';
    updateProgress();
  }, 800);
}

// ===== PROGRESS =====
function updateProgress() {
  const progress = (currentChunk / totalChunks) * 100;
  document.getElementById('progressFill').style.width = progress + '%';
  document.getElementById('progressLabel').textContent = currentChunk + '/' + totalChunks;
}

// ===== NAVIGATION =====
function nextChunk() {
  if (currentChunk < totalChunks) {
    document.getElementById('chunk' + currentChunk).classList.remove('active');
    currentChunk++;
    document.getElementById('chunk' + currentChunk).classList.add('active');
    updateProgress();
    window.scrollTo({ top: 0, behavior: 'smooth' });
    
    // Initialize drag and drop for chunk 5
    if (currentChunk === 5) {
      initDragDrop();
    }
  }
}

function prevChunk() {
  if (currentChunk > 1) {
    document.getElementById('chunk' + currentChunk).classList.remove('active');
    currentChunk--;
    document.getElementById('chunk' + currentChunk).classList.add('active');
    updateProgress();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
}

